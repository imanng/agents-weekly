{
  "name": "agents-weekly",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:web": "pnpm --filter @agents-weekly/web dev",
    "build:web": "pnpm --filter @agents-weekly/web build",
    "dev:crawler": "pnpm --filter @agents-weekly/crawler dev",
    "deploy:crawler": "pnpm --filter @agents-weekly/crawler deploy",
    "lint": "pnpm --filter @agents-weekly/web lint",
    "typecheck": "pnpm --filter @agents-weekly/shared typecheck && pnpm --filter @agents-weekly/crawler typecheck"
  }
}
